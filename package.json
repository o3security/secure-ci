{
    "name": "roc-github-action",
    "version": "1.0.0",
    "description": "GitHub Action for ROC network analysis",
    "main": "index.js",
    "scripts": {
        "build": "npm run build:main && npm run build:post",
        "build:main": "ncc build index.js -o dist",
        "build:post": "ncc build post.js -o dist/post",
        "dev": "node index.js"
    },
    "dependencies": {
        "@actions/core": "^1.10.1",
        "@actions/exec": "^1.1.1",
        "@actions/io": "^1.1.3",
        "fs-extra": "^11.2.0"
    },
    "devDependencies": {
        "@vercel/ncc": "^0.38.1"
    }
}
